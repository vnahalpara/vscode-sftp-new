    "lodash.debounce": "^4.0.8",
    "lru-cache": "^4.1.3",
    "mysql2": "^3.11.5",
    "p-queue": "2.4.2",
    "socks": "^2.8.3",
    "ssh-config": "^1.1.3",
    "ssh2": "^1.17.0",
    "tmp": "^0.2.1",
    "upath": "^2.0.1"
  },
  "jest": {
    "verbose": true,
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.ts$": "<rootDir>/test/preprocessor.js"
    },
    "testMatch": [
      "<rootDir>/test/**/*.spec.js",
      "<rootDir>/**/*/__tests__/*.ts"
    ]
  }
